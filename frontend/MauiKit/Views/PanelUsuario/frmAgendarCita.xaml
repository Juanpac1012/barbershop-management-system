<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage x:Class="MauiKit.Views.PanelUsuario.frmAgendarCita"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MauiKit.Views"
    x:Name="agendarCitaPage"
    Title="Agendar Cita"
    BackgroundColor="{DynamicResource BasePageColor}">

    <views:BasePage.PageContent>
        <ScrollView VerticalScrollBarVisibility="Default">
            <VerticalStackLayout Spacing="25" Padding="20,10">

                <Label Text="Agendar Cita"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{DynamicResource PrimaryColor}"/>

                <Frame CornerRadius="14"
                       HasShadow="True"
                       BackgroundColor="{DynamicResource White}"
                       BorderColor="{DynamicResource Gray400}"
                       Padding="20">

                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Barbero"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <Picker x:Name="cmbBarbero"
                                    TextColor="{DynamicResource BaseTextColor}"
                                    FontSize="16"
                                    ItemDisplayBinding="{Binding NombreCompleto}"
                                    Title=""
                                    BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                    HeightRequest="40"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Servicio"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <Picker x:Name="cmbServicio"
                                    TextColor="{DynamicResource BaseTextColor}"
                                    FontSize="16"
                                    ItemDisplayBinding="{Binding Nombre}"
                                    Title=""
                                    BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                    HeightRequest="40"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Fecha"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <DatePicker x:Name="dpFecha"
                                        TextColor="{DynamicResource BaseTextColor}"
                                        FontSize="16"
                                        MinimumDate="{Binding FechaMinima}"
                                        MaximumDate="{Binding FechaMaxima}"
                                        BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                        HeightRequest="40"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Hora"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <Grid BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                  HeightRequest="40"
                                  HorizontalOptions="Fill"
                                  VerticalOptions="Center">
                                <TimePicker x:Name="tpHora"
                                            TextColor="{DynamicResource BaseTextColor}"
                                            Format="t"
                                            FontSize="16"
                                            Time="{Binding HoraSeleccionada}"
                                            BackgroundColor="Transparent"
                                            HorizontalOptions="Fill"/>
                            </Grid>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>

                <Frame CornerRadius="14"
                       HasShadow="True"
                       BackgroundColor="{DynamicResource White}"
                       BorderColor="{DynamicResource Gray400}"
                       Padding="20"
                       IsVisible="{Binding MostrarResumen}"
                       x:Name="frmResumen">

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Resumen de la Cita"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryColor}"/>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,5,0,10"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" 
                              RowSpacing="10" ColumnSpacing="15">

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Barbero:"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#757575"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   x:Name="lblResumenBarbero"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"/>

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Servicio:"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#757575"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   x:Name="lblResumenServicio"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"/>

                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="Fecha:"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#757575"/>
                            <Label Grid.Row="2" Grid.Column="1"
                                   x:Name="lblResumenFecha"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"/>

                            <Label Grid.Row="3" Grid.Column="0"
                                   Text="Hora:"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#757575"/>
                            <Label Grid.Row="3" Grid.Column="1"
                                   x:Name="lblResumenHora"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Agendar Cita"
                        Clicked="btnAgendar_Clicked"
                        BackgroundColor="{DynamicResource PrimaryColor}"
                        TextColor="{DynamicResource White}"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="50"
                        CornerRadius="10"
                        Margin="0,10">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" 
                                     Binding="{Binding IsBusy}" 
                                     Value="True">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Setter Property="BackgroundColor" Value="#BDBDBD"/>
                            <Setter Property="Text" Value="Procesando..."/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <ActivityIndicator IsVisible="{Binding IsBusy}" 
                                   IsRunning="{Binding IsBusy}"
                                   Color="{DynamicResource PrimaryColor}"
                                   HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.PageContent>
    </views:BasePage>