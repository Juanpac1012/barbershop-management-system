<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage x:Class="MauiKit.Views.PanelUsuario.frmFacturasUsuario"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MauiKit.Views"
    BackgroundColor="{DynamicResource BasePageColor}"
    BaseTitleColor="{DynamicResource BaseTextColor}">

    <views:BasePage.PageContent>
        <ScrollView>
            <VerticalStackLayout Padding="15" Spacing="25">

                <!-- Encabezado -->
                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10" Padding="0,10">
                    <Label FontFamily="MaterialDesign"
                           FontSize="26"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Style="{StaticResource Title2}"
                           Text="Mis Facturas"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Encabezado: Facturas por Citas -->
                <Frame Padding="10"
                       CornerRadius="10"
                       BackgroundColor="{DynamicResource PrimaryColor}"
                       HasShadow="False">
                    <Label Text="Facturas por Citas"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource White}" />
                </Frame>

                <!-- CollectionView: Facturas de Citas -->
                <CollectionView x:Name="facturasCitasCollectionView"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="15"
                                   CornerRadius="20"
                                   BackgroundColor="{DynamicResource White}"
                                   BorderColor="{DynamicResource Gray400}"
                                   HasShadow="True">
                                <Grid ColumnDefinitions="*, Auto"
                                      RowDefinitions="Auto, Auto, Auto, Auto, Auto">

                                    <!-- Estado -->
                                    <Frame Grid.Column="1"
                                           Grid.Row="0"
                                           Padding="8,4"
                                           BackgroundColor="{Binding estado}"
                                           CornerRadius="12"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start">
                                        <Label FontSize="12"
                                               Text="Pendiente de pago"
                                               TextColor="{DynamicResource Black}"
                                               VerticalTextAlignment="Center"
                                               HorizontalTextAlignment="Center" />
                                    </Frame>

                                    <Label Grid.Column="0" Grid.Row="0"
                                           FontAttributes="Bold"
                                           FontSize="18"
                                           Text="{Binding fecha, StringFormat='Fecha: {0:dd/MM/yyyy hh:mm tt}'}"
                                           TextColor="{DynamicResource PrimaryColor}" />

                                    <Label Grid.Column="0" Grid.Row="1"
                                           Margin="0,6"
                                           FontSize="14"
                                           Text="{Binding subtotal, StringFormat='Subtotal: ₡{0:N2}'}"
                                           TextColor="{DynamicResource BaseTextColor}" />

                                    <Label Grid.Column="0" Grid.Row="2"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           Text="{Binding total, StringFormat='Total: ₡{0:N2}'}"
                                           TextColor="{DynamicResource OkColor}" />

                                    <Label Grid.Column="0" Grid.Row="4"
                                           FontSize="14"
                                           Text="{Binding cita.servicio.nombre, FallbackValue='No disponible'}"
                                           TextColor="{DynamicResource BaseTextColor}" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Encabezado: Facturas por Productos -->
                <Frame Padding="10"
                       CornerRadius="10"
                       BackgroundColor="{DynamicResource PrimaryColor}"
                       HasShadow="False">
                    <Label Text="Facturas por Productos"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource White}" />
                </Frame>

                <!-- CollectionView: Facturas de Productos -->
                <CollectionView x:Name="facturasProductosCollectionView"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="15"
                                   CornerRadius="20"
                                   BackgroundColor="{DynamicResource White}"
                                   BorderColor="{DynamicResource Gray400}"
                                   HasShadow="True">
                                <Grid ColumnDefinitions="*, Auto"
                                      RowDefinitions="Auto, Auto, Auto, Auto, Auto">

                                    <!-- Estado -->
                                    <Frame Grid.Column="1"
                                           Grid.Row="0"
                                           Padding="8,4"
                                           BackgroundColor="{Binding estado}"
                                           CornerRadius="12"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start">
                                        <Label FontSize="12"
                                               Text="Pendiente de pago"
                                               TextColor="{DynamicResource Black}"
                                               VerticalTextAlignment="Center"
                                               HorizontalTextAlignment="Center" />
                                    </Frame>

                                    <Label Grid.Column="0" Grid.Row="0"
                                           FontAttributes="Bold"
                                           FontSize="18"
                                           Text="{Binding fecha, StringFormat='Fecha: {0:dd/MM/yyyy hh:mm tt}'}"
                                           TextColor="{DynamicResource PrimaryColor}" />

                                    <Label Grid.Column="0" Grid.Row="1"
                                           Margin="0,6"
                                           FontSize="14"
                                           Text="{Binding subtotal, StringFormat='Subtotal: ₡{0:N2}'}"
                                           TextColor="{DynamicResource BaseTextColor}" />

                                    <Label Grid.Column="0" Grid.Row="2"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           Text="{Binding total, StringFormat='Total: ₡{0:N2}'}"
                                           TextColor="{DynamicResource OkColor}" />

                                    <!-- Lista de Productos -->
                                    <VerticalStackLayout Grid.Column="0" Grid.Row="3"
                                                         Spacing="4"
                                                         BindableLayout.ItemsSource="{Binding productos}">
                                        <Label Text="Productos:"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               TextColor="{DynamicResource BaseTextColor}" />

                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Label FontSize="14"
                                                       TextColor="{DynamicResource BaseTextColor}">
                                                    <Label.Text>
                                                        <MultiBinding StringFormat="• {0} (Cantidad: {1})">
                                                            <Binding Path="nombre" />
                                                            <Binding Path="cantidad" />
                                                        </MultiBinding>
                                                    </Label.Text>
                                                </Label>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.PageContent>
</views:BasePage>
