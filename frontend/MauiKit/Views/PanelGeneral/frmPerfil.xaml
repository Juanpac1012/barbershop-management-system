<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage x:Class="MauiKit.Views.PanelGeneral.frmPerfil"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:localization="clr-namespace:MauiKit.Resources.Translations"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:views="clr-namespace:MauiKit.Views"
    x:Name="profilePage"
    BackgroundColor="{DynamicResource BasePageColor}"
    BaseTitle="{localization:Translate PageTitleProfile}"
    BaseTitleColor="{DynamicResource BaseTextColor}">

    <views:BasePage.PageContent>
        <ScrollView>
        <Grid RowDefinitions="Auto,Auto,Auto">
            <StackLayout Margin="20,15,20,0">

                <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,20" HorizontalOptions="Center">
                    <Border
                        Background="{DynamicResource White}"
                        HeightRequest="120"
                        HorizontalOptions="Center"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeShape="RoundRectangle 60"
                        StrokeThickness="2"
                        WidthRequest="120">

                        <Image
                            Source="imagenperfil.png"
                            Aspect="AspectFill"
                            HeightRequest="110"
                            WidthRequest="110">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangePhotoCommand}"/>
                            </Image.GestureRecognizers>
                        </Image>
                    </Border>
                </VerticalStackLayout>

                <StackLayout Margin="20,10">
                    <Label
                        x:Name="lblNombreApellido"
                        FontSize="20"
                        HorizontalOptions="Center"
                        Style="{StaticResource Title2}"
                        Text="NombreApellido"
                        VerticalTextAlignment="Center" />
                    <Label
                        x:Name="lblCorreo"
                        FontSize="16"
                        HorizontalOptions="Center"
                        Text="Correo"
                        TextColor="{DynamicResource PrimaryColor}"
                        VerticalTextAlignment="Center" />
                </StackLayout>
            </StackLayout>

            <ListView
                Grid.Row="1"
                Margin="20"
                CachingStrategy="RecycleElement"
                HasUnevenRows="False" 
                ItemsSource="{Binding MenuItems}"
                VerticalScrollBarVisibility="Never">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                <Label
                                    FontFamily="IonIcons"
                                    FontSize="22"
                                    HorizontalOptions="Start"
                                    Text="{Binding Icon}"
                                    TextColor="{DynamicResource PrimaryColor}"
                                    VerticalOptions="Center" />

                                <Label
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    HorizontalOptions="Start"
                                    Text="{Binding Title}"
                                    VerticalOptions="Center"
                                    VerticalTextAlignment="Center" />

                                <Label
                                    Grid.Column="2"
                                    FontFamily="IonIcons"
                                    FontSize="15"
                                    HorizontalOptions="End"
                                    HorizontalTextAlignment="Center"
                                    Text="{x:Static views:IonIcons.ChevronRight}"
                                    TextColor="{DynamicResource BaseIconColor}"
                                    VerticalOptions="Center" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference profilePage}, Path=BindingContext.TapCommand}" CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackLayout Grid.Row="2" Padding="20,0">
                <Grid
                    Margin="30"
                    ColumnDefinitions="Auto, *"
                    HorizontalOptions="Center">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="CerrarSesion_Clicked" />
                    </Grid.GestureRecognizers>
                    <Label
                        FontFamily="MaterialDesign"
                        FontSize="25"
                        HorizontalOptions="Center"
                        Text="{x:Static views:MaterialDesignIcons.ExitToApp}"
                        TextColor="{DynamicResource Red}"
                        VerticalOptions="Center" />

                    <Label
                        Grid.Column="1"
                        Margin="12,0"
                        FontSize="15"
                        HorizontalOptions="Start"
                        Style="{StaticResource Title2}"
                        Text="Cerrar Sesión"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />
                </Grid>
            </StackLayout>
        </Grid>
    </ScrollView>
    </views:BasePage.PageContent>
        
</views:BasePage>