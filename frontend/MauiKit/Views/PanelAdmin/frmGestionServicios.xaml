<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage  x:Class="MauiKit.Views.PanelAdmin.frmGestionServicios"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MauiKit.Views"
    x:Name="gestionServicioPage"
    Title="Gestión de Servicios y Productos"
    BackgroundColor="{DynamicResource BasePageColor}">

    <views:BasePage.PageContent>
        <ScrollView VerticalScrollBarVisibility="Default"
                    MinimumHeightRequest="600">
            <VerticalStackLayout Spacing="25" Padding="20,10">

                <Label Text="Gestión de Servicios"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{DynamicResource PrimaryColor}"/>

                <Frame CornerRadius="14"
                       HasShadow="True"
                       BackgroundColor="{DynamicResource White}"
                       BorderColor="{DynamicResource Gray400}"
                       Padding="20"
                       HorizontalOptions="FillAndExpand">

                    <VerticalStackLayout Spacing="20">


                        <VerticalStackLayout Spacing="5">
                            <Label Text="Servicio existente:"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <Picker x:Name="cmbServicio"
                                    TextColor="{DynamicResource BaseTextColor}"
                                    FontSize="16"
                                    ItemDisplayBinding="{Binding nombre}"
                                    Title="Seleccione un servicio para actualizar"
                                    BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                    HeightRequest="75"
                                    HorizontalOptions="FillAndExpand"
                                    Margin="0"
                                    VerticalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Nombre del servicio"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <Entry x:Name="txtNombreServicio"
                                   Placeholder="Nombre del servicio"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                   FontSize="16"
                                   HeightRequest="50"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Descripción"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <Entry x:Name="txtDescripcionServicio"
                                   Placeholder="Descripción del servicio"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                   FontSize="16"
                                   HeightRequest="50"/>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,15,*" ColumnSpacing="5" HorizontalOptions="FillAndExpand">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Duración (min)"
                                       FontSize="16"
                                       TextColor="{DynamicResource BaseTextColor}"
                                       FontAttributes="Bold"/>
                                <Entry x:Name="txtDuracion"
                                       Placeholder="30-300 min"
                                       Keyboard="Numeric"
                                       TextColor="{DynamicResource BaseTextColor}"
                                       BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                       FontSize="16"
                                       HeightRequest="50"/>
                            </VerticalStackLayout>

                            <BoxView Grid.Column="1" Color="Transparent"/>

                            <VerticalStackLayout Grid.Column="2" Spacing="5">
                                <Label Text="Precio (₡)"
                                       FontSize="16"
                                       TextColor="{DynamicResource BaseTextColor}"
                                       FontAttributes="Bold"/>
                                <Entry x:Name="txtPrecioServicio"
                                       Placeholder="0.00"
                                       Keyboard="Numeric"
                                       TextColor="{DynamicResource BaseTextColor}"
                                       BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                       FontSize="16"
                                       HeightRequest="50"/>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <Grid ColumnDefinitions="*,10,*,10,*" ColumnSpacing="0" Margin="0,10" HorizontalOptions="FillAndExpand">

                    <Button x:Name="btnEliminarServicio"
                            Grid.Column="0"
                            Text="Eliminar"
                            Clicked="btnEliminarServicio_Clicked"
                            BackgroundColor="{DynamicResource ErrorColor}"
                            TextColor="{DynamicResource White}"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="50"
                            CornerRadius="10">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" 
                                         Binding="{Binding Source={x:Reference cmbServicio}, Path=SelectedIndex}" 
                                         Value="-1">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <BoxView Grid.Column="1" Color="Transparent"/>

                    <Button x:Name="btnActualizarServicio"
                            Grid.Column="2"
                            Text="Actualizar"
                            Clicked="btnActualizarServicio_Clicked"
                            BackgroundColor="{DynamicResource PrimaryColor}"
                            TextColor="{DynamicResource White}"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="50"
                            CornerRadius="10">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" 
                                         Binding="{Binding Source={x:Reference cmbServicio}, Path=SelectedIndex}" 
                                         Value="-1">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Source={x:Reference txtNombreServicio}, Path=Text.Length}"
                                         Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Source={x:Reference txtDescripcionServicio}, Path=Text.Length}"
                                         Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Source={x:Reference txtDuracion}, Path=Text.Length}"
                                         Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Source={x:Reference txtPrecioServicio}, Path=Text.Length}"
                                         Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <BoxView Grid.Column="3" Color="Transparent"/>

                    <Button x:Name="btnAgregarServicio"
                            Grid.Column="4"
                            Text="Agregar"
                            Clicked="btnAgregarServicio_Clicked"
                            BackgroundColor="{DynamicResource OkColor}"
                            TextColor="{DynamicResource White}"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="50"
                            CornerRadius="10">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Source={x:Reference txtNombreServicio}, Path=Text.Length}"
                                         Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Source={x:Reference txtDescripcionServicio}, Path=Text.Length}"
                                         Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Source={x:Reference txtDuracion}, Path=Text.Length}"
                                         Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding Source={x:Reference txtPrecioServicio}, Path=Text.Length}"
                                         Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <BoxView HeightRequest="1" 
                         BackgroundColor="{DynamicResource Gray300}" 
                         Margin="0,20"/>

                <Label Text="Gestión de Productos"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{DynamicResource PrimaryColor}"/>

                <Frame CornerRadius="14"
                       HasShadow="True"
                       BackgroundColor="{DynamicResource White}"
                       BorderColor="{DynamicResource Gray400}"
                       Padding="20"
                       HorizontalOptions="FillAndExpand">

                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Producto existente:"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <Picker x:Name="cmbProducto"
                                    TextColor="{DynamicResource BaseTextColor}"
                                    FontSize="16"
                                    ItemDisplayBinding="{Binding nombre}"
                                    Title="Seleccione un producto para actualizar"
                                    BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                    HeightRequest="75"
                                    HorizontalOptions="FillAndExpand"
                                    Margin="0"
                                    VerticalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Nombre del producto"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <Entry x:Name="txtNombreProducto"
                                   Placeholder="Nombre del producto"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                   FontSize="16"
                                   HeightRequest="50"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Descripción"
                                   FontSize="16"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   FontAttributes="Bold"/>
                            <Entry x:Name="txtDescripcionProducto"
                                   Placeholder="Descripción del producto"
                                   TextColor="{DynamicResource BaseTextColor}"
                                   BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                   FontSize="16"
                                   HeightRequest="50"/>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,15,*" ColumnSpacing="5" HorizontalOptions="FillAndExpand">

                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Precio (₡)"
                                       FontSize="16"
                                       TextColor="{DynamicResource BaseTextColor}"
                                       FontAttributes="Bold"/>
                                <Entry x:Name="txtPrecioProducto"
                                       Placeholder="0.00"
                                       Keyboard="Numeric"
                                       TextColor="{DynamicResource BaseTextColor}"
                                       BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                       FontSize="16"
                                       HeightRequest="50"/>
                            </VerticalStackLayout>

                            <BoxView Grid.Column="1" Color="Transparent"/>

                            <VerticalStackLayout Grid.Column="2" Spacing="5">
                                <Label Text="Stock"
                                       FontSize="16"
                                       TextColor="{DynamicResource BaseTextColor}"
                                       FontAttributes="Bold"/>
                                <Entry x:Name="txtStock"
                                       Placeholder="Cantidad disponible"
                                       Keyboard="Numeric"
                                       TextColor="{DynamicResource BaseTextColor}"
                                       BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
                                       FontSize="16"
                                       HeightRequest="50"/>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <Grid ColumnDefinitions="*,10,*,10,*" ColumnSpacing="0" Margin="0,10" HorizontalOptions="FillAndExpand">
                    <Button x:Name="btnEliminarProducto"
                            Grid.Column="0"
                            Text="Eliminar"
                            Clicked="btnEliminarProducto_Clicked"
                            BackgroundColor="{DynamicResource ErrorColor}"
                            TextColor="{DynamicResource White}"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="50"
                            CornerRadius="10">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" 
                                         Binding="{Binding Source={x:Reference cmbProducto}, Path=SelectedIndex}" 
                                         Value="-1">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <BoxView Grid.Column="1" Color="Transparent"/>

                    <Button x:Name="btnActualizarProducto"
                            Grid.Column="2"
                            Text="Actualizar"
                            Clicked="btnActualizarProducto_Clicked"
                            BackgroundColor="{DynamicResource PrimaryColor}"
                            TextColor="{DynamicResource White}"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="50"
                            CornerRadius="10">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" 
                                   Binding="{Binding Source={x:Reference cmbProducto}, Path=SelectedIndex}" 
                                   Value="-1">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                   Binding="{Binding Source={x:Reference txtNombreProducto}, Path=Text.Length}"
                                   Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                   Binding="{Binding Source={x:Reference txtDescripcionProducto}, Path=Text.Length}"
                                   Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                   Binding="{Binding Source={x:Reference txtPrecioProducto}, Path=Text.Length}"
                                   Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                   Binding="{Binding Source={x:Reference txtStock}, Path=Text.Length}"
                                   Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <BoxView Grid.Column="3" Color="Transparent"/>

                    <Button x:Name="btnAgregarProducto"
                            Grid.Column="4"
                            Text="Agregar"
                            Clicked="btnAgregarProducto_Clicked"
                            BackgroundColor="{DynamicResource OkColor}"
                            TextColor="{DynamicResource White}"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="50"
                            CornerRadius="10">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                   Binding="{Binding Source={x:Reference txtNombreProducto}, Path=Text.Length}"
                                   Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                   Binding="{Binding Source={x:Reference txtDescripcionProducto}, Path=Text.Length}"
                                   Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                   Binding="{Binding Source={x:Reference txtPrecioProducto}, Path=Text.Length}"
                                   Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                   Binding="{Binding Source={x:Reference txtStock}, Path=Text.Length}"
                                   Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="BackgroundColor" Value="{DynamicResource Gray300}"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <ActivityIndicator IsVisible="{Binding IsBusy}" 
                                   IsRunning="{Binding IsBusy}"
                                   Color="{DynamicResource PrimaryColor}"
                                   HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </ScrollView>
    </views:BasePage.PageContent>
    </views:BasePage>